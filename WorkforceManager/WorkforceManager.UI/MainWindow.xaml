<Window x:Class="WorkforceManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="نظام إدارة إنتاجية وأجور العمال"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI" FontSize="14">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════ القائمة الجانبية ══════════ -->
        <Border Grid.Column="0">
            <!-- تدرج كحلي هادي من فوق لتحت — عمق من غير ما يتعب العين -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#24437C" Offset="0" />
                    <GradientStop Color="#152A4E" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <DockPanel>
                <!-- الهوية: لوجو + اسم النظام -->
                <StackPanel DockPanel.Dock="Top" Margin="18,26,18,22">
                    <Border Width="54" Height="54" CornerRadius="16" Background="#2EFFFFFF"
                            HorizontalAlignment="Right">
                        <TextBlock Text="🏭" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="إدارة الإنتاجية" Foreground="White" FontSize="18" FontWeight="Bold"
                               Margin="0,12,0,2" />
                    <TextBlock Text="نظام اليوميات والأجور والتقييم" Foreground="#9FB3D1" FontSize="11.5" />
                </StackPanel>

                <!-- بطاقة اليوم في آخر القائمة -->
                <Border DockPanel.Dock="Bottom" Margin="14,0,14,16" Padding="12,10"
                        CornerRadius="10" Background="#1AFFFFFF">
                    <StackPanel>
                        <!-- التاريخ بالعربي بيتكتب من الكود عند فتح النافذة -->
                        <TextBlock x:Name="TodayText" Foreground="White" FontSize="12.5" FontWeight="SemiBold" />
                        <TextBlock Text="أسبوع العمل: الخميس ← الأربعاء" Foreground="#9FB3D1" FontSize="10.5"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Border>

                <!-- عناصر التنقل -->
                <StackPanel Margin="12,4,12,0">
                    <!-- التنقل بـ Checked + Click مع بعض عن قصد:
                         Checked للتنقل الفعلي والكيبورد، وClick لإعادة تحميل الشاشة
                         المفتوحة أصلًا (Checked مبيتنفذش لو الزرار متعلم بالفعل) -->
                    <RadioButton Style="{StaticResource NavItem}" IsChecked="True"
                                 Checked="NavWorkers_Checked" Click="NavWorkers_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="العمال والمهارات" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavItem}"
                                 Checked="NavProducts_Checked" Click="NavProducts_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="المنتجات والمراحل" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavItem}"
                                 Checked="NavDailyEntry_Checked" Click="NavDailyEntry_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="تسجيل الإنتاج اليومي" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavItem}"
                                 Checked="NavReports_Checked" Click="NavReports_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="التقارير والتقييم" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════ منطقة المحتوى ══════════ -->
        <Border Grid.Column="1" Background="{StaticResource PageBgBrush}">
            <ContentControl x:Name="MainContent" Margin="18,16" />
        </Border>
    </Grid>
</Window>
