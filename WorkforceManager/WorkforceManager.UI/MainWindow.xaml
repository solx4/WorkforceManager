<Window x:Class="WorkforceManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="نظام إدارة إنتاجية وأجور العمال"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI" FontSize="14">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- القائمة الجانبية -->
        <Border Grid.Column="0" Background="#1F3864">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="إدارة الإنتاجية"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           Margin="16,0,16,24" TextAlignment="Right" />

                <RadioButton Content="العمال والمهارات" Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="White" Margin="16,8" IsChecked="True" Click="NavWorkers_Click" />
                <RadioButton Content="المنتجات والمراحل" Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="White" Margin="16,8" Click="NavProducts_Click" />
                <RadioButton Content="تسجيل الإنتاج اليومي" Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="White" Margin="16,8" Click="NavDailyEntry_Click" />
                <RadioButton Content="التقارير والتقييم" Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="White" Margin="16,8" Click="NavReports_Click" />
            </StackPanel>
        </Border>

        <!-- منطقة المحتوى: كل شاشة (View) بتتحمّل هنا -->
        <ContentControl x:Name="MainContent" Grid.Column="1" Margin="16" />
    </Grid>
</Window>
