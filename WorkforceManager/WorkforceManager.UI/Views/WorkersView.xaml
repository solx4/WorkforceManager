<UserControl x:Class="WorkforceManager.UI.Views.WorkersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <!-- شاشة العمال: شريط أدوات فوق + جدول العمال في النص + لوحة تفاصيل (بروفايل) على الجنب -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- شريط الأدوات: بحث موحّد + إظهار الموقوفين + زرار الإضافة -->
        <Border Grid.Row="0" Background="#F2F4F8" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="＋ إضافة عامل جديد"
                        Command="{Binding AddWorkerCommand}"
                        Background="#1F3864" Foreground="White" Padding="14,8" BorderThickness="0"
                        FontWeight="Bold" Cursor="Hand" />

                <CheckBox DockPanel.Dock="Left" Content="إظهار الموقوفين"
                          IsChecked="{Binding ShowInactive}"
                          VerticalAlignment="Center" Margin="16,0" />

                <Button DockPanel.Dock="Right" Content="🔍 بحث"
                        Command="{Binding SearchCommand}"
                        Padding="14,8" Margin="8,0,0,0" Cursor="Hand" />

                <!-- البحث الموحّد: بالاسم أو بالمهارة/المرحلة — Enter بينفذ البحث مباشرة -->
                <TextBox VerticalAlignment="Center" Padding="8,6" FontSize="14"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- عنوان الأسبوع الحالي -->
        <TextBlock Grid.Row="1" Text="{Binding WeekTitle}"
                   FontSize="13" Foreground="#555" Margin="4,0,4,6" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <!-- جدول العمال بإحصائيات الأسبوع الحالي -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Workers}"
                      SelectedItem="{Binding SelectedWorker}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" CanUserAddRows="False"
                      FontSize="13" RowHeight="34" BorderThickness="1" BorderBrush="#DDD">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="⭐" Binding="{Binding BestMark}" Width="36" />
                    <DataGridTextColumn Header="اسم العامل" Binding="{Binding FullName}" Width="*" />
                    <DataGridTextColumn Header="الكود" Binding="{Binding EmployeeCode}" Width="70" />
                    <DataGridTextColumn Header="حضور" Binding="{Binding PresentDays}" Width="60" />
                    <DataGridTextColumn Header="غياب بإذن" Binding="{Binding AbsentWithPermissionDays}" Width="80" />
                    <DataGridTextColumn Header="غياب بدون إذن" Binding="{Binding AbsentWithoutPermissionDays}" Width="100" />
                    <DataGridTextColumn Header="خصم جزاءات" Binding="{Binding PenaltyDeduction}" Width="90" />
                    <DataGridTextColumn Header="صافي اليوميات" Binding="{Binding NetWorkdays}" Width="100" />
                    <DataGridTextColumn Header="الحالة" Binding="{Binding StatusText}" Width="70" />
                </DataGrid.Columns>
                <!-- تمييز الصف حسب الحالة: الموقوف رمادي باهت -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                <Setter Property="Foreground" Value="#999" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <!-- لوحة التفاصيل (بروفايل العامل المحدد) -->
            <Border Grid.Column="1" Background="#FAFBFD" BorderBrush="#DDD" BorderThickness="1"
                    CornerRadius="6" Margin="8,0,0,0" Padding="12">
                <Grid>
                    <!-- رسالة لما مفيش عامل محدد -->
                    <TextBlock Text="اختار عامل من الجدول لعرض ملفه الكامل"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#999" FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Detail}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" DataContext="{Binding Detail}">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel>
                            <!-- رأس البروفايل + أزرار الإدارة -->
                            <TextBlock Text="{Binding FullName}" FontSize="18" FontWeight="Bold" Foreground="#1F3864"
                                       TextWrapping="Wrap" />
                            <TextBlock FontSize="12" Foreground="#666" Margin="0,2,0,8">
                                <Run Text="الكود: " /><Run Text="{Binding EmployeeCode, Mode=OneWay}" />
                                <Run Text="   تليفون: " /><Run Text="{Binding PhoneNumber, Mode=OneWay}" />
                                <Run Text="   التحق: " /><Run Text="{Binding HireDateText, Mode=OneWay}" />
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="✏ تعديل"
                                        Command="{Binding DataContext.EditWorkerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Padding="10,5" Margin="0,0,6,0" Cursor="Hand" />
                                <Button Padding="10,5" Cursor="Hand"
                                        Command="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Content" Value="🗑 إيقاف العامل" />
                                            <Setter Property="Foreground" Value="#B00020" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Content" Value="↩ إعادة تفعيل" />
                                                    <Setter Property="Foreground" Value="#0B6E4F" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- المهارات -->
                            <TextBlock Text="المهارات (المراحل اللي بيعرف يعملها)" FontWeight="Bold" Margin="0,4,0,4" />
                            <ItemsControl ItemsSource="{Binding Skills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#E8EDF7" CornerRadius="4" Padding="6,3" Margin="0,2">
                                            <DockPanel>
                                                <!-- زرار شيل المهارة -->
                                                <Button DockPanel.Dock="Left" Content="✕" FontSize="10" Padding="4,0"
                                                        Background="Transparent" BorderThickness="0" Foreground="#B00020" Cursor="Hand"
                                                        Command="{Binding DataContext.RemoveSkillCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                <TextBlock Text="{Binding Display}" FontSize="12" TextWrapping="Wrap" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- إضافة مهارة جديدة -->
                            <DockPanel Margin="0,6,0,10">
                                <Button DockPanel.Dock="Left" Content="＋ إضافة" Padding="8,4" Cursor="Hand"
                                        Command="{Binding DataContext.AddSkillCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <ComboBox ItemsSource="{Binding StageOptions}"
                                          SelectedItem="{Binding SelectedStageOption}"
                                          DisplayMemberPath="Display" Margin="0,0,6,0" FontSize="12" />
                            </DockPanel>

                            <!-- ملاحظات المهارات النصية (المرجع القديم من ملف الإكسل) -->
                            <TextBlock Text="ملاحظات المهارات (المرجع النصي)" FontWeight="Bold" Margin="0,4,0,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SkillsNotes}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding SkillsNotes}" FontSize="12" Foreground="#555"
                                       TextWrapping="Wrap" Margin="0,0,0,10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SkillsNotes}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- الهستوري الأسبوعي -->
                            <TextBlock Text="الهستوري الأسبوعي (آخر 8 أسابيع)" FontWeight="Bold" Margin="0,4,0,4" />
                            <ItemsControl ItemsSource="{Binding WeeklyHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,6">
                                            <StackPanel>
                                                <TextBlock FontSize="12.5" FontWeight="SemiBold">
                                                    <Run Text="{Binding BestMark, Mode=OneWay}" />
                                                    <Run Text="{Binding WeekTitle, Mode=OneWay}" />
                                                </TextBlock>
                                                <TextBlock FontSize="12" Foreground="#444" Margin="0,2,0,0">
                                                    <Run Text="أنتج: " /><Run Text="{Binding Produced, Mode=OneWay}" FontWeight="Bold" />
                                                    <Run Text="   خصم غياب: " /><Run Text="{Binding AbsenceDeduction, Mode=OneWay}" Foreground="#B00020" />
                                                    <Run Text="   خصم جزاءات: " /><Run Text="{Binding PenaltyDeduction, Mode=OneWay}" Foreground="#B00020" />
                                                    <Run Text="   الصافي: " /><Run Text="{Binding Net, Mode=OneWay}" FontWeight="Bold" Foreground="#1F3864" />
                                                </TextBlock>
                                                <!-- تفاصيل الإنتاج (لو فيه) -->
                                                <TextBlock FontSize="11" Foreground="#777" TextWrapping="Wrap"
                                                           Text="{Binding BreakdownText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasBreakdown}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- الجزاءات بأسبابها (لو فيه) -->
                                                <TextBlock FontSize="11" Foreground="#B00020" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasPenalties}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="جزاءات: " /><Run Text="{Binding PenaltiesText, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
