<Window x:Class="WorkforceManager.UI.Views.StageEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إضافة مرحلة جديدة"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        FlowDirection="RightToLeft" FontSize="14" FontFamily="Segoe UI">

    <!-- نافذة إضافة/تعديل مرحلة تصنيع بكوتة يوميتها -->
    <StackPanel Margin="20">
        <TextBlock Text="اسم المرحلة (إجباري)" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="NameBox" Padding="8,6" Margin="0,0,0,12" />

        <TextBlock Text="كوتة اليومية: عدد القطع اللي بتساوي يومية عمل كاملة (إجباري)" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="QuotaBox" Padding="8,6" Margin="0,0,0,4" />
        <!-- تنبيه مهم: تعديل الكوتة مش بيأثر على السجلات القديمة (محمية بالـ Snapshot) -->
        <TextBlock Text="ملحوظة: تعديل الكوتة يسري على التسجيلات الجديدة فقط — الحسابات القديمة محفوظة زي ما كانت."
                   FontSize="11.5" Foreground="#B7791F" TextWrapping="Wrap" Margin="0,0,0,12" />

        <TextBlock Text="الترتيب داخل خط الإنتاج (اختياري — بياخد آخر ترتيب تلقائيًا)" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="SortOrderBox" Padding="8,6" Margin="0,0,0,16" />

        <TextBlock x:Name="ErrorText" Foreground="#B00020" FontSize="12"
                   Margin="0,0,0,8" Visibility="Collapsed" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="حفظ" Click="Save_Click" IsDefault="True"
                    Style="{StaticResource PrimaryButton}" Padding="26,9" Margin="0,0,8,0" />
            <Button Content="إلغاء" IsCancel="True" Style="{StaticResource GhostButton}" Padding="26,9" />
        </StackPanel>
    </StackPanel>
</Window>
