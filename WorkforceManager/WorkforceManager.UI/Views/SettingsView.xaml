<UserControl x:Class="WorkforceManager.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <!-- شاشة الإعدادات: النسخ الاحتياطي المحلي والخارجي والاسترجاع -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" HorizontalAlignment="Right">

            <!-- النسخ المحلي -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🗄 النسخ الاحتياطي المحلي" Style="{StaticResource SectionTitle}" />
                    <TextBlock Style="{StaticResource HintText}" Margin="0,4,0,10"
                               Text="نسخة تلقائية بتتاخد كل يوم أول ما البرنامج يفتح، والنسخ الأقدم من 30 يوم بتتمسح لوحدها." />
                    <TextBlock Text="{Binding LocalFolderText}" FontSize="12.5"
                               Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LocalStatusText}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,10" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="💾 خد نسخة دلوقتي" Command="{Binding BackupNowCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" />
                        <Button Content="📂 فتح مجلد النسخ" Command="{Binding OpenLocalFolderCommand}"
                                Style="{StaticResource GhostButton}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- النسخ الخارجي -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🛡 النسخ الخارجي (فلاشة / قرص تاني)" Style="{StaticResource SectionTitle}" />
                    <TextBlock Style="{StaticResource HintText}" Margin="0,4,0,10"
                               Text="أهم حماية لبياناتك: النسخة المحلية على نفس الهارد — لو الهارد نفسه باظ بتضيع معاه. المجلد الخارجي بياخد نسخة تانية تلقائيًا كل يوم." />
                    <TextBlock Text="{Binding ExternalFolderText}" FontSize="12.5" FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ExternalStatusText}" FontSize="12.5"
                               Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,10" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="📁 اختيار المجلد الخارجي" Command="{Binding ChooseExternalFolderCommand}"
                                Style="{StaticResource SuccessButton}" Margin="0,0,8,0" />
                        <Button Content="إيقاف النسخ الخارجي" Command="{Binding DisableExternalCommand}"
                                Foreground="{StaticResource DangerBrush}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasExternal}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- الاسترجاع -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="⏪ استرجاع نسخة احتياطية" Style="{StaticResource SectionTitle}" />
                    <TextBlock Style="{StaticResource HintText}" Margin="0,4,0,10"
                               Text="لو حصلت مشكلة كبيرة في البيانات، تقدر ترجع لأي نسخة سابقة. البيانات الحالية بتتستبدل — وبناخد نسخة أمان منها الأول تلقائيًا، والبرنامج بيعيد تشغيل نفسه بعد الاسترجاع." />
                    <Button Content="⏪ استرجاع من نسخة..." Command="{Binding RestoreBackupCommand}"
                            Style="{StaticResource DangerButton}" HorizontalAlignment="Right" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
