<Window x:Class="WorkforceManager.UI.Views.PayslipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="قسيمة أجر" Height="720" Width="640"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft" FontFamily="Segoe UI"
        Background="{StaticResource PageBgBrush}">

    <DockPanel Margin="0">
        <!-- شريط الأدوات (مش بيتطبع) -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BrandBrush}" Padding="14,10">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Content="🖨 طباعة" Click="Print_Click"
                        Style="{StaticResource SuccessButton}" />
                <Button DockPanel.Dock="Left" Content="إغلاق" Click="Close_Click"
                        Style="{StaticResource GhostButton}" Foreground="White" Margin="8,0,0,0" />
                <TextBlock DockPanel.Dock="Right" Text="معاينة قبل الطباعة" Foreground="#B9C8E2"
                           VerticalAlignment="Center" FontSize="12.5" />
            </DockPanel>
        </Border>

        <!-- منطقة الطباعة -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <Border x:Name="PrintArea" Background="White" Width="560" Padding="30"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <!-- الرأس -->
                    <TextBlock Text="قسيمة أجر" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource BrandBrush}" HorizontalAlignment="Center" />
                    <Border Height="3" Width="60" CornerRadius="2" Background="{StaticResource AccentBrush}"
                            HorizontalAlignment="Center" Margin="0,8,0,16" />

                    <TextBlock Text="{Binding WorkerName}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding WorkerSubtitle}" FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding PeriodText}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource BrandBrush}" HorizontalAlignment="Center" Margin="0,6,0,18" />

                    <!-- سطور التفصيل -->
                    <StackPanel>
                        <StackPanel.Resources>
                            <Style TargetType="DockPanel">
                                <Setter Property="Margin" Value="0,0,0,9" />
                            </Style>
                            <Style x:Key="Lbl" TargetType="TextBlock">
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                            <Style x:Key="Val" TargetType="TextBlock" BasedOn="{StaticResource Lbl}">
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                        </StackPanel.Resources>

                        <DockPanel Visibility="{Binding ShowPieces, Converter={StaticResource BoolToVis}}">
                            <TextBlock DockPanel.Dock="Left" Text="إجمالي القطع" Style="{StaticResource Lbl}" />
                            <TextBlock Text="{Binding TotalPiecesText}" Style="{StaticResource Val}" HorizontalAlignment="Left" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="اليوميات المنتجة" Style="{StaticResource Lbl}" />
                            <TextBlock Text="{Binding ProducedWorkdaysText}" Style="{StaticResource Val}" HorizontalAlignment="Left" />
                        </DockPanel>
                        <DockPanel Visibility="{Binding ShowAbsence, Converter={StaticResource BoolToVis}}">
                            <TextBlock DockPanel.Dock="Left" Text="خصم غياب بدون إذن" Style="{StaticResource Lbl}" />
                            <TextBlock Text="{Binding AbsenceDeductionText}" Style="{StaticResource Val}"
                                       Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Left" />
                        </DockPanel>
                        <DockPanel Visibility="{Binding ShowPenalty, Converter={StaticResource BoolToVis}}">
                            <TextBlock DockPanel.Dock="Left" Text="خصم جزاءات" Style="{StaticResource Lbl}" />
                            <TextBlock Text="{Binding PenaltyDeductionText}" Style="{StaticResource Val}"
                                       Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Left" />
                        </DockPanel>

                        <Border Height="1" Background="{StaticResource CardBorderBrush}" Margin="0,4,0,12" />

                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="صافي اليوميات" Style="{StaticResource Lbl}" />
                            <TextBlock Text="{Binding NetWorkdaysText}" Style="{StaticResource Val}" HorizontalAlignment="Left" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="سعر اليومية" Style="{StaticResource Lbl}" />
                            <TextBlock Text="{Binding DailyWageText}" Style="{StaticResource Val}" HorizontalAlignment="Left" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="أجر اليوميات" Style="{StaticResource Lbl}" />
                            <TextBlock Text="{Binding WorkdaysWageText}" Style="{StaticResource Val}" HorizontalAlignment="Left" />
                        </DockPanel>
                        <DockPanel Visibility="{Binding ShowBonus, Converter={StaticResource BoolToVis}}">
                            <TextBlock DockPanel.Dock="Left" Text="حوافز ومكافآت" Style="{StaticResource Lbl}" />
                            <TextBlock Text="{Binding BonusText}" Style="{StaticResource Val}"
                                       Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Left" />
                        </DockPanel>
                        <DockPanel Visibility="{Binding ShowAdvance, Converter={StaticResource BoolToVis}}">
                            <TextBlock DockPanel.Dock="Left" Text="سلف ومسحوبات" Style="{StaticResource Lbl}" />
                            <TextBlock Text="{Binding AdvanceText}" Style="{StaticResource Val}"
                                       Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Left" />
                        </DockPanel>
                    </StackPanel>

                    <!-- الأجر النهائي -->
                    <Border Background="{StaticResource SuccessBgBrush}" CornerRadius="10" Padding="16,12" Margin="0,14,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="الأجر النهائي المستحق" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding NetWageText}" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <!-- التوقيع -->
                    <Grid Margin="0,34,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <Border Height="1" Background="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="توقيع المستلم" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <Border Height="1" Background="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="توقيع المسؤول" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding PrintedAtText}" FontSize="10.5" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,20,0,0" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </DockPanel>
</Window>
