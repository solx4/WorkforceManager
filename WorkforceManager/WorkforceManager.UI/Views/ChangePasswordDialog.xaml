<Window x:Class="WorkforceManager.UI.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تغيير كلمة المرور"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        FlowDirection="RightToLeft" FontSize="14" FontFamily="Segoe UI">

    <!-- تغيير كلمة المرور: بيتطلب الحالية الأول (التحقق في AuthService) -->
    <StackPanel Margin="20">
        <TextBlock Text="اسم المستخدم" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="UsernameBox" Padding="8,6" Margin="0,0,0,12" />

        <TextBlock Text="كلمة المرور الحالية" FontWeight="Bold" Margin="0,0,0,4" />
        <PasswordBox x:Name="CurrentBox" Padding="8,6" Margin="0,0,0,12" />

        <TextBlock Text="كلمة المرور الجديدة (4 على الأقل)" FontWeight="Bold" Margin="0,0,0,4" />
        <PasswordBox x:Name="NewBox" Padding="8,6" Margin="0,0,0,12" />

        <TextBlock Text="تأكيد كلمة المرور الجديدة" FontWeight="Bold" Margin="0,0,0,4" />
        <PasswordBox x:Name="ConfirmBox" Padding="8,6" Margin="0,0,0,16" />

        <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" FontSize="12"
                   Margin="0,0,0,8" Visibility="Collapsed" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="تغيير" Click="Save_Click" IsDefault="True"
                    Style="{StaticResource PrimaryButton}" Padding="26,9" Margin="0,0,8,0" />
            <Button Content="إلغاء" IsCancel="True" Style="{StaticResource GhostButton}" Padding="26,9" />
        </StackPanel>
    </StackPanel>
</Window>
