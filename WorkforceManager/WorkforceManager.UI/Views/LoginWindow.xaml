<Window x:Class="WorkforceManager.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل الدخول — إدارة الإنتاجية"
        Width="880" Height="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        FlowDirection="RightToLeft" FontFamily="Segoe UI" FontSize="14">

    <!-- شاشة الدخول الترحيبية: بطاقة عائمة بلا إطار نظام —
         يمين: لوحة الهوية بالتدرج الكحلي، شمال: فورم الدخول -->
    <Border CornerRadius="20" Background="White" MouseLeftButtonDown="Window_Drag">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.25" Color="#1F3864" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ══════ لوحة الهوية (يمين) ══════ -->
            <Border Grid.Column="0" CornerRadius="20,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#24437C" Offset="0" />
                        <GradientStop Color="#152A4E" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- دواير زخرفية شفافة — عمق بصري بسيط من غير زحمة -->
                    <Ellipse Width="220" Height="220" Fill="#0DFFFFFF"
                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-60,-60,0,0" />
                    <Ellipse Width="160" Height="160" Fill="#0DFFFFFF"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-40,-40" />

                    <StackPanel VerticalAlignment="Center" Margin="34,0">
                        <Border Width="76" Height="76" CornerRadius="22" Background="#2EFFFFFF"
                                HorizontalAlignment="Right">
                            <TextBlock Text="🏭" FontSize="38" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="إدارة الإنتاجية" Foreground="White" FontSize="26" FontWeight="Bold"
                                   Margin="0,18,0,4" />
                        <TextBlock Text="نظام اليوميات والأجور والتقييم" Foreground="#B9C8E2" FontSize="14" />
                        <Border Height="3" Width="52" CornerRadius="2" Background="#F2A93B"
                                HorizontalAlignment="Right" Margin="0,16,0,16" />
                        <TextBlock Foreground="#9FB3D1" FontSize="12.5" TextWrapping="Wrap" LineHeight="20"
                                   Text="تسجيل الإنتاج برحلات المنتجات، حساب اليوميات والخصومات تلقائيًا، وكشف الأسبوع جاهز بضغطة واحدة." />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════ فورم الدخول (شمال) ══════ -->
            <Grid Grid.Column="1">
                <!-- زرار إغلاق البرنامج -->
                <Button Content="✕" FontSize="14" Foreground="#8A94A6"
                        Style="{StaticResource IconButton}" Padding="8,4"
                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14"
                        ToolTip="إغلاق البرنامج" Click="Close_Click" />

                <StackPanel VerticalAlignment="Center" Margin="56,0">
                    <TextBlock Text="أهلاً بيك 👋" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="سجّل دخولك عشان تكمل شغلك" FontSize="13.5"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,26" />

                    <TextBlock Text="اسم المستخدم" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6" />
                    <TextBox x:Name="UsernameBox" Padding="10,8" FontSize="14" Margin="0,0,0,16" />

                    <TextBlock Text="كلمة المرور" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6" />
                    <PasswordBox x:Name="PasswordBox" Padding="10,8" FontSize="14" Margin="0,0,0,8" />

                    <!-- رسالة الخطأ (بتظهر بس لما الدخول يفشل) -->
                    <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" FontSize="12.5"
                               Visibility="Collapsed" TextWrapping="Wrap" Margin="0,0,0,6" />

                    <Button Content="تسجيل الدخول" Click="Login_Click" IsDefault="True"
                            Style="{StaticResource PrimaryButton}" FontSize="14.5"
                            Padding="0,11" Margin="0,10,0,14"
                            HorizontalAlignment="Stretch" />

                    <!-- تغيير كلمة المرور من غير ما يدخل البرنامج -->
                    <TextBlock HorizontalAlignment="Center">
                        <Hyperlink Click="ChangePassword_Click" TextDecorations="None">
                            <Run Text="تغيير كلمة المرور" Foreground="#3B5BA5" FontSize="12.5" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
