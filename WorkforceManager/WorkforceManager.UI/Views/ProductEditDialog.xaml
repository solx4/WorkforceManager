<Window x:Class="WorkforceManager.UI.Views.ProductEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إضافة منتج جديد"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        FlowDirection="RightToLeft" FontSize="14" FontFamily="Segoe UI">

    <!-- نافذة إضافة/تعديل منتج: نفس الفورم للحالتين، بيتملى مسبقًا في التعديل -->
    <StackPanel Margin="20">
        <TextBlock Text="اسم المنتج (إجباري)" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="NameBox" Padding="8,6" Margin="0,0,0,12" />

        <TextBlock Text="كود المنتج" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="CodeBox" Padding="8,6" Margin="0,0,0,12" />

        <TextBlock Text="وصف (اختياري)" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="DescriptionBox" Padding="8,6" Margin="0,0,0,16"
                 TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                 VerticalScrollBarVisibility="Auto" />

        <TextBlock x:Name="ErrorText" Foreground="#B00020" FontSize="12"
                   Margin="0,0,0,8" Visibility="Collapsed" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="حفظ" Click="Save_Click" IsDefault="True"
                    Style="{StaticResource PrimaryButton}" Padding="26,9" Margin="0,0,8,0" />
            <Button Content="إلغاء" IsCancel="True" Style="{StaticResource GhostButton}" Padding="26,9" />
        </StackPanel>
    </StackPanel>
</Window>
