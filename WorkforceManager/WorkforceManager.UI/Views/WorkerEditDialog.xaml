<Window x:Class="WorkforceManager.UI.Views.WorkerEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إضافة عامل جديد"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        FlowDirection="RightToLeft" FontSize="14" FontFamily="Segoe UI">

    <!-- نافذة إضافة/تعديل عامل: نفس الفورم للحالتين، بيتملى مسبقًا في حالة التعديل -->
    <StackPanel Margin="20">
        <TextBlock Text="اسم العامل (إجباري)" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="NameBox" Padding="8,6" Margin="0,0,0,12" />

        <TextBlock Text="الكود الوظيفي" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="CodeBox" Padding="8,6" Margin="0,0,0,12" />

        <TextBlock Text="رقم التليفون" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="PhoneBox" Padding="8,6" Margin="0,0,0,12" />

        <TextBlock Text="تاريخ الالتحاق" FontWeight="Bold" Margin="0,0,0,4" />
        <DatePicker x:Name="HireDatePicker" Margin="0,0,0,12" />

        <TextBlock Text="سعر اليومية بالجنيه" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="WageBox" Padding="8,6" Margin="0,0,0,4" />
        <TextBlock Text="الأجر = صافي اليوميات × السعر ده. سيبه 0 لحد ما تحدد سعر العامل."
                   Style="{StaticResource HintText}" Margin="0,0,0,12" />

        <TextBlock Text="نوع الحساب" FontWeight="Bold" Margin="0,0,0,4" />
        <ComboBox x:Name="HourlyRoleBox" Padding="8,6" Margin="0,0,0,4"
                  DisplayMemberPath="Display" SelectedValuePath="Role" />
        <TextBlock Text="عامل الإنتاج بيتحاسب بالقطعة (من مهاراته). العامل بالساعة (رص/جودة/تدريب) بيتحاسب بالساعات ويظهر في تبويب منفصل."
                   Style="{StaticResource HintText}" Margin="0,0,0,14" />

        <TextBlock Text="ملاحظات المهارات (اختياري)" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="NotesBox" Padding="8,6" Margin="0,0,0,16"
                 TextWrapping="Wrap" AcceptsReturn="True" Height="70"
                 VerticalScrollBarVisibility="Auto" />

        <!-- رسالة الخطأ (بتظهر لو الاسم فاضي مثلاً) -->
        <TextBlock x:Name="ErrorText" Foreground="#B00020" FontSize="12"
                   Margin="0,0,0,8" Visibility="Collapsed" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="حفظ" Click="Save_Click" IsDefault="True"
                    Style="{StaticResource PrimaryButton}" Padding="26,9" Margin="0,0,8,0" />
            <Button Content="إلغاء" IsCancel="True" Style="{StaticResource GhostButton}" Padding="26,9" />
        </StackPanel>
    </StackPanel>
</Window>
