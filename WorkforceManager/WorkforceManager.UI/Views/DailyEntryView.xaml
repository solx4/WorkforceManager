<UserControl x:Class="WorkforceManager.UI.Views.DailyEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WorkforceManager.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <!-- شاشة التسجيل اليومي: اختيار اليوم فوق + 3 تبويبات (إنتاج / حضور / جزاءات) لنفس اليوم -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- اختيار اليوم (مشترك لكل التبويبات) -->
        <Border Grid.Row="0" Background="#F2F4F8" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="اليوم:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
                <DatePicker SelectedDate="{Binding EntryDate}" Width="160" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" BorderThickness="1" BorderBrush="#DDD">

            <!-- ============ تبويب الإنتاج ============ -->
            <TabItem Header="  تسجيل الإنتاج  ">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- اختيار المنتج والمرحلة -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="المنتج:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                                  DisplayMemberPath="Name" Width="180" Margin="0,0,16,0" />
                        <TextBlock Text="المرحلة:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding Stages}" SelectedItem="{Binding SelectedStage}"
                                  DisplayMemberPath="StageName" Width="180" Margin="0,0,16,0" />
                        <TextBlock Text="{Binding StageInfo}" Foreground="#1F3864" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- جدول إدخال القطع للعمال -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Entries}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowHeight="36" FontSize="13" BorderThickness="1" BorderBrush="#DDD">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="اسم العامل" Binding="{Binding FullName}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="الكود" Binding="{Binding EmployeeCode}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="" Binding="{Binding AlreadyRecordedText}" Width="130" IsReadOnly="True" />
                            <!-- خانة عدد القطع: TextBox مباشر عشان الكتابة تكون بضغطة واحدة من غير Double Click -->
                            <DataGridTemplateColumn Header="عدد القطع النهارده" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding PiecesText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="6,4" Margin="4,2" FontSize="14"
                                                 VerticalContentAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- ملاحظة العمال المؤهلين + زر الحفظ -->
                    <DockPanel Grid.Row="2" Margin="0,8,0,0">
                        <Button DockPanel.Dock="Left" Content="💾 حفظ إنتاج اليوم كله"
                                Command="{Binding SaveProductionCommand}"
                                Background="#1F3864" Foreground="White" Padding="18,9"
                                BorderThickness="0" FontWeight="Bold" Cursor="Hand" />
                        <TextBlock Text="{Binding QualifiedNote}" Foreground="#B7791F" FontSize="12"
                                   VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap" />
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ============ تبويب الحضور ============ -->
            <TabItem Header="  الحضور والغياب  ">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding AttendanceRows}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowHeight="36" FontSize="13" BorderThickness="1" BorderBrush="#DDD">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="اسم العامل" Binding="{Binding FullName}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="الكود" Binding="{Binding EmployeeCode}" Width="80" IsReadOnly="True" />
                            <!-- حالة الحضور: قائمة منسدلة مباشرة في الجدول -->
                            <DataGridTemplateColumn Header="حالة اليوم" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{x:Static vm:DailyEntryViewModel.StatusOptions}"
                                                  SelectedItem="{Binding SelectedStatus, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="Display" Margin="4,2" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="1" Content="💾 حفظ الحضور" HorizontalAlignment="Left"
                            Command="{Binding SaveAttendanceCommand}"
                            Background="#1F3864" Foreground="White" Padding="18,9"
                            BorderThickness="0" FontWeight="Bold" Margin="0,8,0,0" Cursor="Hand" />
                </Grid>
            </TabItem>

            <!-- ============ تبويب الجزاءات ============ -->
            <TabItem Header="  الجزاءات  ">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- فورم تسجيل جزاء جديد -->
                    <Border Grid.Row="0" Background="#FDF6F6" BorderBrush="#E5C9C9" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="تسجيل جزاء جديد" FontWeight="Bold" Foreground="#B00020" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="العامل:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox ItemsSource="{Binding AttendanceRows}" SelectedItem="{Binding PenaltyWorker}"
                                          DisplayMemberPath="FullName" Width="220" Margin="0,0,14,0" />
                                <TextBlock Text="الخصم:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox ItemsSource="{Binding DeductionOptions}" SelectedItem="{Binding SelectedDeduction}"
                                          DisplayMemberPath="Display" Width="110" Margin="0,0,14,0" />
                            </StackPanel>
                            <DockPanel Margin="0,8,0,0">
                                <Button DockPanel.Dock="Left" Content="＋ تسجيل الجزاء"
                                        Command="{Binding AddPenaltyCommand}"
                                        Background="#B00020" Foreground="White" Padding="14,7"
                                        BorderThickness="0" FontWeight="Bold" Cursor="Hand" />
                                <TextBlock Text="السبب:" VerticalAlignment="Center" Margin="12,0,6,0" DockPanel.Dock="Left" />
                                <!-- سبب الجزاء نص حر: شرب سجاير، لبس هاندفري، ... -->
                                <TextBox Text="{Binding PenaltyReason, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,6" VerticalAlignment="Center" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- جزاءات اليوم المسجلة -->
                    <GroupBox Grid.Row="1" Header="جزاءات اليوم المسجلة" FontSize="13">
                        <DataGrid ItemsSource="{Binding DayPenalties}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowHeight="34" FontSize="13" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="العامل" Binding="{Binding WorkerName}" Width="*" />
                                <DataGridTextColumn Header="السبب" Binding="{Binding Reason}" Width="2*" />
                                <DataGridTextColumn Header="الخصم" Binding="{Binding DeductionName}" Width="90" />
                                <DataGridTemplateColumn Header="" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑 حذف" FontSize="11" Padding="6,3" Cursor="Hand"
                                                    Foreground="#B00020" Background="Transparent" BorderThickness="0"
                                                    Command="{Binding DataContext.RemovePenaltyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
