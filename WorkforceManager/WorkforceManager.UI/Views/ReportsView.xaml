<UserControl x:Class="WorkforceManager.UI.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <!-- شاشة التقارير: تبويبين — تقييم اليوم + كشف الأسبوع (مع تصدير Excel) -->
    <TabControl BorderThickness="1" BorderBrush="#DDD">

        <!-- ============ تبويب تقييم اليوم ============ -->
        <TabItem Header="  تقييم اليوم  ">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- اختيار اليوم + سطر الملخص -->
                <Border Grid.Row="0" Style="{StaticResource ToolbarCard}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="اليوم:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <DatePicker SelectedDate="{Binding DailyDate}" Width="160" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DailySummaryText}" Foreground="{StaticResource BrandBrush}" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="20,0,0,0" />
                    </StackPanel>
                </Border>

                <!-- جدول التقييم اليومي -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
                <DataGrid ItemsSource="{Binding DailyRows}"
                          Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="اسم العامل" Binding="{Binding WorkerName}" Width="*" />
                        <DataGridTextColumn Header="القطع" Binding="{Binding TotalPieces}" Width="70" />
                        <DataGridTextColumn Header="اليوميات" Binding="{Binding TotalWorkdays}" Width="80" />
                        <DataGridTextColumn Header="مقارنة بالمتوسط" Binding="{Binding PercentText}" Width="110" />
                        <!-- التقييم بلونه المميز (اللون جاي جاهز من الـ ViewModel) -->
                        <DataGridTemplateColumn Header="التقييم" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RatingText}" Foreground="{Binding RatingColor}"
                                               FontWeight="Bold" VerticalAlignment="Center" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="الحضور" Binding="{Binding AttendanceText}" Width="100" />
                        <DataGridTextColumn Header="اشتغل على" Binding="{Binding BreakdownText}" Width="2*" />
                        <DataGridTextColumn Header="جزاءات اليوم" Binding="{Binding PenaltiesText}" Width="150" />
                    </DataGrid.Columns>
                </DataGrid>
                </Border>
            </Grid>
        </TabItem>

        <!-- ============ تبويب كشف الأسبوع ============ -->
        <TabItem Header="  كشف الأسبوع  ">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- شريط التنقل بين الأسابيع + التصدير -->
                <Border Grid.Row="0" Style="{StaticResource ToolbarCard}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Button Content="◀ الأسبوع السابق" Command="{Binding PreviousWeekCommand}"
                                    Style="{StaticResource GhostButton}" Margin="0,0,6,0" />
                            <Button Content="الأسبوع الحالي" Command="{Binding CurrentWeekCommand}"
                                    Style="{StaticResource GhostButton}" Margin="0,0,6,0" />
                            <Button Content="الأسبوع التالي ▶" Command="{Binding NextWeekCommand}"
                                    Style="{StaticResource GhostButton}" />
                        </StackPanel>

                        <Button DockPanel.Dock="Left" Content="📊 تصدير Excel"
                                Command="{Binding ExportWeekCommand}"
                                Style="{StaticResource SuccessButton}" Margin="16,0,0,0" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="16,0,0,0">
                            <TextBlock Text="{Binding WeekTitle}" FontWeight="Bold" Foreground="{StaticResource BrandBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding WeekBadge}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- جدول كشف الأسبوع (مرتّب بالصافي) -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
                <DataGrid ItemsSource="{Binding WeeklyRows}"
                          SelectedItem="{Binding SelectedWeeklyRow}"
                          Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="40" />
                        <DataGridTextColumn Header="⭐" Binding="{Binding BestMark}" Width="36" />
                        <DataGridTextColumn Header="اسم العامل" Binding="{Binding WorkerName}" Width="*" />
                        <DataGridTextColumn Header="الكود" Binding="{Binding EmployeeCode}" Width="65" />
                        <DataGridTextColumn Header="أنتج" Binding="{Binding ProducedWorkdays}" Width="65" />
                        <DataGridTextColumn Header="القطع" Binding="{Binding TotalPieces}" Width="75" />
                        <DataGridTextColumn Header="حضور" Binding="{Binding PresentDays}" Width="60" />
                        <DataGridTextColumn Header="غياب بإذن" Binding="{Binding AbsentWithPermissionDays}" Width="80" />
                        <DataGridTextColumn Header="بدون إذن" Binding="{Binding AbsentWithoutPermissionDays}" Width="75" />
                        <DataGridTextColumn Header="خصم غياب" Binding="{Binding AbsenceDeduction}" Width="80" />
                        <DataGridTextColumn Header="خصم جزاءات" Binding="{Binding PenaltyDeduction}" Width="90" />
                        <!-- الصافي بالخط العريض وبلونه (أحمر لو سالب) -->
                        <DataGridTemplateColumn Header="الصافي" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NetWorkdays}" Foreground="{Binding NetColor}"
                                               FontWeight="Bold" VerticalAlignment="Center" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <!-- الأجر بالجنيه -->
                        <DataGridTextColumn Header="الأجر (ج)" Binding="{Binding WageText}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                </Border>

                <!-- لوحة تفاصيل العامل المحدد في الكشف -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,10,0,0" MinHeight="70"
                        DataContext="{Binding SelectedWeeklyRow}">
                    <StackPanel>
                        <TextBlock FontWeight="Bold" Foreground="#1F3864">
                            <Run Text="{Binding BestMark, Mode=OneWay}" />
                            <Run Text="{Binding WorkerName, Mode=OneWay}" />
                            <Run Text=" — تفاصيل الأسبوع" />
                        </TextBlock>
                        <TextBlock FontSize="12.5" Foreground="#444" TextWrapping="Wrap" Margin="0,4,0,0">
                            <Run Text="الإنتاج: " FontWeight="SemiBold" />
                            <Run Text="{Binding BreakdownText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="12.5" Foreground="#B00020" TextWrapping="Wrap" Margin="0,3,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPenalties}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="الجزاءات: " FontWeight="SemiBold" />
                            <Run Text="{Binding PenaltiesText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>

        <!-- ============ تبويب رسم إنتاج المنتجات ============ -->
        <TabItem Header="  إنتاج المنتجات 📈  ">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- اختيار المدة -->
                <Border Grid.Row="0" Style="{StaticResource ToolbarCard}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="المدة: آخر" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding ChartWeeksOptions}"
                                  SelectedItem="{Binding SelectedChartWeeks}" Width="70" />
                        <TextBlock Text="أسبوع" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,16,0" />
                        <TextBlock Style="{StaticResource HintText}" FontSize="12" VerticalAlignment="Center"
                                   Text="القطع المكتملة فقط: المسجلة على آخر مرحلة لكل منتج — الشغل الجاري على المراحل الأبكر مش بيتحسب" />
                    </StackPanel>
                </Border>

                <!-- مفتاح الألوان (منتج = لون) -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding ChartLegend}" Margin="4,0,4,8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2,18,2">
                                <Border Width="13" Height="13" CornerRadius="3" Background="{Binding Color}"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" FontSize="12.5"
                                           VerticalAlignment="Center" Margin="6,0,4,0" />
                                <TextBlock Text="{Binding TotalText}" Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11.5" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- الرسم البياني -->
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <!-- رسالة لما مفيش بيانات -->
                        <TextBlock Text="مفيش إنتاج مكتمل متسجل في الفترة دي — سجّل رحلات إنتاج توصل لآخر مرحلة وهتظهر هنا"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="14" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="400">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ChartHasData}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- محور الزمن ثابت شمال ← يمين زي أي رسم بياني (مع بقاء النصوص عربي) -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                      FlowDirection="LeftToRight" VerticalAlignment="Bottom">
                            <ItemsControl ItemsSource="{Binding ChartWeekGroups}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- مجموعة أعمدة أسبوع واحد -->
                                        <StackPanel Margin="10,0" MinWidth="52">
                                            <!-- الأعمدة (كل منتج بلونه) مثبتة على خط الأرض -->
                                            <Grid Height="200">
                                                <ItemsControl ItemsSource="{Binding Bars}" VerticalAlignment="Bottom"
                                                              HorizontalAlignment="Center">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="20" Height="{Binding Height}"
                                                                    Background="{Binding Color}" CornerRadius="4,4,0,0"
                                                                    Margin="2,0" VerticalAlignment="Bottom"
                                                                    ToolTip="{Binding Tooltip}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>

                                            <!-- خط الأرض + تاريخ الأسبوع + إجماليه -->
                                            <Border Height="1.5" Background="{StaticResource CardBorderBrush}" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding WeekLabel}" FontSize="11.5" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding TotalText}" FontSize="10.5"
                                                       HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!-- ============ تبويب كشف الأجور (فترة مخصصة/شهري) ============ -->
        <TabItem Header="  كشف الأجور 💵  ">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- اختيار الفترة + تصدير -->
                <Border Grid.Row="0" Style="{StaticResource ToolbarCard}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="من:" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <DatePicker DockPanel.Dock="Left" SelectedDate="{Binding PayrollFrom}" Width="150"
                                    VerticalAlignment="Center" Margin="0,0,12,0" />
                        <TextBlock DockPanel.Dock="Left" Text="إلى:" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <DatePicker DockPanel.Dock="Left" SelectedDate="{Binding PayrollTo}" Width="150"
                                    VerticalAlignment="Center" Margin="0,0,12,0" />
                        <Button DockPanel.Dock="Left" Content="🔄 عرض" Command="{Binding RefreshPayrollCommand}"
                                Style="{StaticResource GhostButton}" Margin="0,0,8,0" />
                        <Button DockPanel.Dock="Left" Content="📊 تصدير Excel" Command="{Binding ExportPayrollCommand}"
                                Style="{StaticResource SuccessButton}" />
                        <TextBlock Text="{Binding PayrollTotalText}" HorizontalAlignment="Left"
                                   Foreground="{StaticResource BrandBrush}" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="16,0,0,0" TextWrapping="Wrap" />
                    </DockPanel>
                </Border>

                <TextBlock Grid.Row="1" Style="{StaticResource HintText}" FontSize="12" Margin="4,0,4,8"
                           Text="الأجر = صافي اليوميات (إنتاج + ساعات − خصومات الغياب والجزاءات) × سعر يومية العامل. اختار من تاريخ لتاريخ (شهر مثلاً) وصدّره لحساب الرواتب." />

                <!-- جدول الأجور -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Padding="6">
                    <Grid>
                        <TextBlock Text="مفيش نشاط في الفترة دي — اختار فترة تانية أو سجّل إنتاج/شغل أول"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PayrollRows.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <DataGrid ItemsSource="{Binding PayrollRows}"
                                  Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="40" />
                                <DataGridTextColumn Header="اسم العامل" Binding="{Binding WorkerName}" Width="*" />
                                <DataGridTextColumn Header="الكود" Binding="{Binding EmployeeCode}" Width="70" />
                                <DataGridTextColumn Header="النوع" Binding="{Binding TypeText}" Width="75" />
                                <DataGridTextColumn Header="أيام العمل" Binding="{Binding DaysWorked}" Width="85" />
                                <DataGridTextColumn Header="صافي اليوميات" Binding="{Binding NetWorkdays}" Width="105" />
                                <DataGridTextColumn Header="سعر اليومية" Binding="{Binding DailyWageText}" Width="100" />
                                <!-- الأجر النهائي بارز بالأخضر -->
                                <DataGridTextColumn Header="الأجر بالجنيه" Binding="{Binding NetWageText}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="FontSize" Value="14" />
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!-- ============ تبويب التقرير العام للإنتاج ============ -->
        <TabItem Header="  تقرير الإنتاج 📋  ">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- اختيار المدة: أزرار سريعة + مدى مخصص + تصدير -->
                <Border Grid.Row="0" Style="{StaticResource ToolbarCard}">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left" Content="اليوم" Command="{Binding GeneralPeriodCommand}" CommandParameter="day"
                                Style="{StaticResource GhostButton}" Margin="0,0,6,0" />
                        <Button DockPanel.Dock="Left" Content="الأسبوع" Command="{Binding GeneralPeriodCommand}" CommandParameter="week"
                                Style="{StaticResource GhostButton}" Margin="0,0,6,0" />
                        <Button DockPanel.Dock="Left" Content="الشهر" Command="{Binding GeneralPeriodCommand}" CommandParameter="month"
                                Style="{StaticResource GhostButton}" Margin="0,0,16,0" />
                        <TextBlock DockPanel.Dock="Left" Text="من:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <DatePicker DockPanel.Dock="Left" SelectedDate="{Binding GeneralFrom}" Width="140" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock DockPanel.Dock="Left" Text="إلى:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <DatePicker DockPanel.Dock="Left" SelectedDate="{Binding GeneralTo}" Width="140" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Button DockPanel.Dock="Left" Content="🔄 عرض" Command="{Binding RefreshGeneralCommand}"
                                Style="{StaticResource GhostButton}" Margin="0,0,8,0" />
                        <Button DockPanel.Dock="Left" Content="📊 تصدير Excel" Command="{Binding ExportGeneralCommand}"
                                Style="{StaticResource SuccessButton}" />
                    </DockPanel>
                </Border>

                <!-- سطر الملخص الإجمالي للقسم -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,8" Padding="12,8">
                    <TextBlock Text="{Binding GeneralSummaryText}" Foreground="{StaticResource BrandBrush}"
                               FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                </Border>

                <!-- جدولين جنب بعض: بالمنتج/المرحلة + بالعامل -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- الإنتاج بالمنتج والمرحلة -->
                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="6" Margin="0,0,5,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="الإنتاج حسب المنتج والمرحلة" FontWeight="Bold"
                                       Foreground="{StaticResource BrandBrush}" Margin="4,2,4,6" />
                            <DataGrid ItemsSource="{Binding GeneralByProductStage}"
                                      Style="{StaticResource ModernDataGrid}"
                                      AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="*" />
                                    <DataGridTextColumn Header="المرحلة" Binding="{Binding StageDisplay}" Width="*" />
                                    <DataGridTextColumn Header="القطع" Binding="{Binding Pieces}" Width="70" />
                                    <DataGridTextColumn Header="اليوميات" Binding="{Binding Workdays}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- الإنتاج بالعامل -->
                    <Border Grid.Column="1" Style="{StaticResource Card}" Padding="6" Margin="5,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="الإنتاج حسب العامل" FontWeight="Bold"
                                       Foreground="{StaticResource BrandBrush}" Margin="4,2,4,6" />
                            <DataGrid ItemsSource="{Binding GeneralByWorker}"
                                      Style="{StaticResource ModernDataGrid}"
                                      AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="40" />
                                    <DataGridTextColumn Header="اسم العامل" Binding="{Binding WorkerName}" Width="*" />
                                    <DataGridTextColumn Header="النوع" Binding="{Binding TypeText}" Width="90" />
                                    <DataGridTextColumn Header="القطع" Binding="{Binding TotalPieces}" Width="85" />
                                    <DataGridTextColumn Header="اليوميات" Binding="{Binding TotalWorkdays}" Width="85" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ============ تبويب تقرير عامل معيّن ============ -->
        <TabItem Header="  تقرير عامل 👤  ">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- اختيار العامل + المدة + تصدير -->
                <Border Grid.Row="0" Style="{StaticResource ToolbarCard}">
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="العامل:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox DockPanel.Dock="Left" ItemsSource="{Binding Workers}" SelectedItem="{Binding SelectedWorker}"
                                  DisplayMemberPath="Display" Width="200" VerticalAlignment="Center" Margin="0,0,16,0" />
                        <Button DockPanel.Dock="Left" Content="اليوم" Command="{Binding WorkerPeriodCommand}" CommandParameter="day"
                                Style="{StaticResource GhostButton}" Margin="0,0,6,0" />
                        <Button DockPanel.Dock="Left" Content="الأسبوع" Command="{Binding WorkerPeriodCommand}" CommandParameter="week"
                                Style="{StaticResource GhostButton}" Margin="0,0,6,0" />
                        <Button DockPanel.Dock="Left" Content="الشهر" Command="{Binding WorkerPeriodCommand}" CommandParameter="month"
                                Style="{StaticResource GhostButton}" Margin="0,0,16,0" />
                        <TextBlock DockPanel.Dock="Left" Text="من:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <DatePicker DockPanel.Dock="Left" SelectedDate="{Binding WorkerFrom}" Width="130" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock DockPanel.Dock="Left" Text="إلى:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <DatePicker DockPanel.Dock="Left" SelectedDate="{Binding WorkerTo}" Width="130" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Button DockPanel.Dock="Left" Content="🔄 عرض" Command="{Binding RefreshWorkerCommand}"
                                Style="{StaticResource GhostButton}" Margin="0,0,8,0" />
                        <Button DockPanel.Dock="Left" Content="📊 تصدير Excel" Command="{Binding ExportWorkerCommand}"
                                Style="{StaticResource SuccessButton}" />
                    </DockPanel>
                </Border>

                <!-- ملخص العامل: العنوان + الإنتاج/الحضور + الأجر -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,8" Padding="12,8">
                    <StackPanel>
                        <TextBlock Text="{Binding WorkerReportHeader}" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource BrandBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding WorkerProductionText}" FontSize="12.5" Foreground="#444"
                                   TextWrapping="Wrap" Margin="0,5,0,0" Visibility="{Binding HasWorkerReport, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding WorkerWageText}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Visibility="{Binding HasWorkerReport, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- التفاصيل: إنتاج بالمرحلة + إنتاج باليوم + الجزاءات -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1.3*" />
                    </Grid.ColumnDefinitions>

                    <!-- يسار: إنتاج بالمرحلة + الجزاءات -->
                    <Grid Grid.Column="0" Margin="0,0,5,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="6">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="الإنتاج حسب المرحلة" FontWeight="Bold"
                                           Foreground="{StaticResource BrandBrush}" Margin="4,2,4,6" />
                                <DataGrid ItemsSource="{Binding WorkerByProductStage}"
                                          Style="{StaticResource ModernDataGrid}"
                                          AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="*" />
                                        <DataGridTextColumn Header="المرحلة" Binding="{Binding StageDisplay}" Width="*" />
                                        <DataGridTextColumn Header="القطع" Binding="{Binding Pieces}" Width="85" />
                                        <DataGridTextColumn Header="اليوميات" Binding="{Binding Workdays}" Width="85" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6" Margin="0,10,0,0" MaxHeight="180">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="الجزاءات" FontWeight="Bold"
                                           Foreground="{StaticResource DangerBrush}" Margin="4,2,4,6" />
                                <DataGrid ItemsSource="{Binding WorkerPenalties}"
                                          Style="{StaticResource ModernDataGrid}"
                                          AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="التاريخ" Binding="{Binding DateText}" Width="100" />
                                        <DataGridTextColumn Header="السبب" Binding="{Binding Reason}" Width="*" />
                                        <DataGridTextColumn Header="الخصم" Binding="{Binding DeductionName}" Width="90" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- يمين: إنتاج يوم بيوم -->
                    <Border Grid.Column="1" Style="{StaticResource Card}" Padding="6" Margin="5,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="الإنتاج يوم بيوم" FontWeight="Bold"
                                       Foreground="{StaticResource BrandBrush}" Margin="4,2,4,6" />
                            <DataGrid ItemsSource="{Binding WorkerByDay}"
                                      Style="{StaticResource ModernDataGrid}"
                                      AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="التاريخ" Binding="{Binding DateText}" Width="160" />
                                    <DataGridTextColumn Header="القطع" Binding="{Binding Pieces}" Width="85" />
                                    <DataGridTextColumn Header="اليوميات" Binding="{Binding Workdays}" Width="85" />
                                    <DataGridTextColumn Header="التفصيل" Binding="{Binding Detail}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
