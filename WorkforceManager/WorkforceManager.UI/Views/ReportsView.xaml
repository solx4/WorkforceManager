<UserControl x:Class="WorkforceManager.UI.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <!-- شاشة التقارير: تبويبين — تقييم اليوم + كشف الأسبوع (مع تصدير Excel) -->
    <TabControl BorderThickness="1" BorderBrush="#DDD">

        <!-- ============ تبويب تقييم اليوم ============ -->
        <TabItem Header="  تقييم اليوم  ">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- اختيار اليوم + سطر الملخص -->
                <Border Grid.Row="0" Style="{StaticResource ToolbarCard}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="اليوم:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <DatePicker SelectedDate="{Binding DailyDate}" Width="160" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DailySummaryText}" Foreground="{StaticResource BrandBrush}" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="20,0,0,0" />
                    </StackPanel>
                </Border>

                <!-- جدول التقييم اليومي -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
                <DataGrid ItemsSource="{Binding DailyRows}"
                          Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="اسم العامل" Binding="{Binding WorkerName}" Width="*" />
                        <DataGridTextColumn Header="القطع" Binding="{Binding TotalPieces}" Width="70" />
                        <DataGridTextColumn Header="اليوميات" Binding="{Binding TotalWorkdays}" Width="80" />
                        <DataGridTextColumn Header="مقارنة بالمتوسط" Binding="{Binding PercentText}" Width="110" />
                        <!-- التقييم بلونه المميز (اللون جاي جاهز من الـ ViewModel) -->
                        <DataGridTemplateColumn Header="التقييم" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RatingText}" Foreground="{Binding RatingColor}"
                                               FontWeight="Bold" VerticalAlignment="Center" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="الحضور" Binding="{Binding AttendanceText}" Width="100" />
                        <DataGridTextColumn Header="اشتغل على" Binding="{Binding BreakdownText}" Width="2*" />
                        <DataGridTextColumn Header="جزاءات اليوم" Binding="{Binding PenaltiesText}" Width="150" />
                    </DataGrid.Columns>
                </DataGrid>
                </Border>
            </Grid>
        </TabItem>

        <!-- ============ تبويب كشف الأسبوع ============ -->
        <TabItem Header="  كشف الأسبوع  ">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- شريط التنقل بين الأسابيع + التصدير -->
                <Border Grid.Row="0" Style="{StaticResource ToolbarCard}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Button Content="◀ الأسبوع السابق" Command="{Binding PreviousWeekCommand}"
                                    Style="{StaticResource GhostButton}" Margin="0,0,6,0" />
                            <Button Content="الأسبوع الحالي" Command="{Binding CurrentWeekCommand}"
                                    Style="{StaticResource GhostButton}" Margin="0,0,6,0" />
                            <Button Content="الأسبوع التالي ▶" Command="{Binding NextWeekCommand}"
                                    Style="{StaticResource GhostButton}" />
                        </StackPanel>

                        <Button DockPanel.Dock="Left" Content="📊 تصدير Excel"
                                Command="{Binding ExportWeekCommand}"
                                Style="{StaticResource SuccessButton}" Margin="16,0,0,0" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="16,0,0,0">
                            <TextBlock Text="{Binding WeekTitle}" FontWeight="Bold" Foreground="{StaticResource BrandBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding WeekBadge}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- جدول كشف الأسبوع (مرتّب بالصافي) -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
                <DataGrid ItemsSource="{Binding WeeklyRows}"
                          SelectedItem="{Binding SelectedWeeklyRow}"
                          Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="40" />
                        <DataGridTextColumn Header="⭐" Binding="{Binding BestMark}" Width="36" />
                        <DataGridTextColumn Header="اسم العامل" Binding="{Binding WorkerName}" Width="*" />
                        <DataGridTextColumn Header="الكود" Binding="{Binding EmployeeCode}" Width="65" />
                        <DataGridTextColumn Header="أنتج" Binding="{Binding ProducedWorkdays}" Width="65" />
                        <DataGridTextColumn Header="القطع" Binding="{Binding TotalPieces}" Width="75" />
                        <DataGridTextColumn Header="حضور" Binding="{Binding PresentDays}" Width="60" />
                        <DataGridTextColumn Header="غياب بإذن" Binding="{Binding AbsentWithPermissionDays}" Width="80" />
                        <DataGridTextColumn Header="بدون إذن" Binding="{Binding AbsentWithoutPermissionDays}" Width="75" />
                        <DataGridTextColumn Header="خصم غياب" Binding="{Binding AbsenceDeduction}" Width="80" />
                        <DataGridTextColumn Header="خصم جزاءات" Binding="{Binding PenaltyDeduction}" Width="90" />
                        <!-- الصافي بالخط العريض وبلونه (أحمر لو سالب) -->
                        <DataGridTemplateColumn Header="الصافي" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NetWorkdays}" Foreground="{Binding NetColor}"
                                               FontWeight="Bold" VerticalAlignment="Center" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                </Border>

                <!-- لوحة تفاصيل العامل المحدد في الكشف -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,10,0,0" MinHeight="70"
                        DataContext="{Binding SelectedWeeklyRow}">
                    <StackPanel>
                        <TextBlock FontWeight="Bold" Foreground="#1F3864">
                            <Run Text="{Binding BestMark, Mode=OneWay}" />
                            <Run Text="{Binding WorkerName, Mode=OneWay}" />
                            <Run Text=" — تفاصيل الأسبوع" />
                        </TextBlock>
                        <TextBlock FontSize="12.5" Foreground="#444" TextWrapping="Wrap" Margin="0,4,0,0">
                            <Run Text="الإنتاج: " FontWeight="SemiBold" />
                            <Run Text="{Binding BreakdownText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="12.5" Foreground="#B00020" TextWrapping="Wrap" Margin="0,3,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPenalties}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="الجزاءات: " FontWeight="SemiBold" />
                            <Run Text="{Binding PenaltiesText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>

        <!-- ============ تبويب رسم إنتاج المنتجات ============ -->
        <TabItem Header="  إنتاج المنتجات 📈  ">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- اختيار المدة -->
                <Border Grid.Row="0" Style="{StaticResource ToolbarCard}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="المدة: آخر" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding ChartWeeksOptions}"
                                  SelectedItem="{Binding SelectedChartWeeks}" Width="70" />
                        <TextBlock Text="أسبوع" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,16,0" />
                        <TextBlock Style="{StaticResource HintText}" FontSize="12" VerticalAlignment="Center"
                                   Text="القطع المكتملة فقط: المسجلة على آخر مرحلة لكل منتج — الشغل الجاري على المراحل الأبكر مش بيتحسب" />
                    </StackPanel>
                </Border>

                <!-- مفتاح الألوان (منتج = لون) -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding ChartLegend}" Margin="4,0,4,8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2,18,2">
                                <Border Width="13" Height="13" CornerRadius="3" Background="{Binding Color}"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" FontSize="12.5"
                                           VerticalAlignment="Center" Margin="6,0,4,0" />
                                <TextBlock Text="{Binding TotalText}" Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11.5" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- الرسم البياني -->
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <!-- رسالة لما مفيش بيانات -->
                        <TextBlock Text="مفيش إنتاج مكتمل متسجل في الفترة دي — سجّل رحلات إنتاج توصل لآخر مرحلة وهتظهر هنا"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="14" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="400">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ChartHasData}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- محور الزمن ثابت شمال ← يمين زي أي رسم بياني (مع بقاء النصوص عربي) -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                      FlowDirection="LeftToRight" VerticalAlignment="Bottom">
                            <ItemsControl ItemsSource="{Binding ChartWeekGroups}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- مجموعة أعمدة أسبوع واحد -->
                                        <StackPanel Margin="10,0" MinWidth="52">
                                            <!-- الأعمدة (كل منتج بلونه) مثبتة على خط الأرض -->
                                            <Grid Height="200">
                                                <ItemsControl ItemsSource="{Binding Bars}" VerticalAlignment="Bottom"
                                                              HorizontalAlignment="Center">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="20" Height="{Binding Height}"
                                                                    Background="{Binding Color}" CornerRadius="4,4,0,0"
                                                                    Margin="2,0" VerticalAlignment="Bottom"
                                                                    ToolTip="{Binding Tooltip}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>

                                            <!-- خط الأرض + تاريخ الأسبوع + إجماليه -->
                                            <Border Height="1.5" Background="{StaticResource CardBorderBrush}" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding WeekLabel}" FontSize="11.5" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding TotalText}" FontSize="10.5"
                                                       HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
